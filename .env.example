# Copy variable names into the cloud Agent's secret manager. Do not commit real values.

# Optional: only for explicitly invoking the standalone Agnes image skill
AGNES_API_KEY=

# Optional: set only when the HTML cover renderer cannot auto-detect Chrome/Chromium
WECHAT_COVER_BROWSER=

# Required for WeChat account A
WECHAT_A_APP_ID=
WECHAT_A_APP_SECRET=

# Required for WeChat account B
WECHAT_B_APP_ID=
WECHAT_B_APP_SECRET=

# Optional permanent-cover fallback when HTML cover rendering is unavailable
WECHAT_A_THUMB_MEDIA_ID=
WECHAT_B_THUMB_MEDIA_ID=
